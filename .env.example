# 复制本文件为 .env 并填入真实值（勿提交 .env 到 Git）

# DeepSeek API Key — https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-your-deepseek-key-here

# 小红书 PC 端 Cookie（登录 xiaohongshu.com 后 F12 → 网络 → 复制 cookie）
# 参考 https://github.com/cv-cat/Spider_XHS
XHS_COOKIES=your_xhs_cookie_string_here

# 可选：聚合数据「互联网资讯」API（当前版本未接入写作流程）
# JUHE_API_KEY=your_juhe_key_here
